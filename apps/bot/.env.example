# Core APIs
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=...
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
CRYPTOPANIC_API_KEY=...
NEWS_API_KEY=...

# Exchange config
EXCHANGE_ID=binance
EXCHANGE_API_KEY=...
EXCHANGE_API_SECRET=...
EXCHANGE_MARKET_TYPE=spot

# Trade mode
TRADE_MODE=paper

# Paper trading settings
BOT_PAPER_TRADE_SIZE=200
BOT_MIN_CONFIDENCE=0.65
BOT_MIN_RR=1.5

# Live trading settings (only used when TRADE_MODE=live)
BOT_LIVE_TRADE_SIZE=10
BOT_LIVE_MIN_CONFIDENCE=0.75
BOT_LIVE_MIN_RR=1.8
BOT_LIVE_MIN_VOLUME=5000000
BOT_LIVE_MAX_POSITIONS=3
BOT_LIVE_MAX_DAILY_SPEND=50
BOT_LIVE_ORDER_TTL_MINUTES=15
BOT_LIVE_SLIPPAGE_TOLERANCE=0.002

# Strategy settings
BOT_MAX_PAIRS=30
BOT_STRATEGY_INTERVAL_MINUTES=5
BOT_DEFAULT_STOP_ATR_MULT=1.5
BOT_DEFAULT_TARGET_ATR_MULT=2.5
LOG_LEVEL=INFO
